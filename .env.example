# ── MongoDB ────────────────────────────────────────────────────────────────────
# Production: MongoDB Atlas connection string
# Development: mongodb://localhost:27017/
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=burningregister

# ── Backend ────────────────────────────────────────────────────────────────────
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8080
DEBUG=false
LOG_LEVEL=info

# Allowed origins for CORS — set to your Cloudflare Pages domain in production
CORS_ORIGINS=["http://localhost:5173"]

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be set — no default in production
SECRET_KEY=replace-me-with-a-secure-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Superuser (first run only) ─────────────────────────────────────────────────
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_EMAIL=admin@example.com
# Must be changed immediately after first login
FIRST_SUPERUSER_PASSWORD=replace-me

# ── Frontend (Cloudflare Pages build-time variable) ────────────────────────────
# Set this in the Cloudflare Pages dashboard, not here
# VUE_APP_DB_ADDRESS=https://<your-backend>.up.railway.app
